# ─────────────────────────────────────────────────────────────────────────────
# Environment template for the server (Vercel) AND the collector.
#
#   Server:    copy to `server/.env` for local dev. In production, set each
#              variable in Vercel → Project Settings → Environment Variables.
#   Collector: the Windows installer writes a `config.json` instead — these
#              vars are only used when running `python collector/collector.py`
#              directly for testing.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# From Supabase dashboard → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# anon/public key — safe to ship to the browser, used by the dashboard UI
SUPABASE_ANON_KEY=eyJhbGciOi...

# service_role key — SERVER ONLY. Bypasses Row-Level Security. Never expose.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── Ingest auth ───────────────────────────────────────────────────────────────
# Shared secret baked into the installer. Collectors send this in the
# X-Ingest-Token header so randoms can't POST junk to /api/ingest.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
INGEST_TOKEN=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ── Storage bucket ────────────────────────────────────────────────────────────
# Supabase Storage bucket where raw JSONL files are uploaded.
# Created by the schema migration; you should not need to change this.
STORAGE_BUCKET=claude-raw

# ── Collector-only (overridden by config.json on installed machines) ──────────
# Where the server is reachable. The collector POSTs to {SERVER_URL}/api/ingest.
SERVER_URL=https://your-vercel-app.vercel.app
