# ─────────────────────────────────────────────────────────────────────────────
# Environment template for the hosted dashboard server (Vercel).
#
# Copy to `server/.env` for local dev. In production, set each variable in
# Vercel → Project Settings → Environment Variables.
#
# The collector lives in a separate repo:
#   https://github.com/samirtak-dynatechconsultancy/claude-usage-exe
# It uses a config.json instead of env vars.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# From Supabase dashboard → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# anon/public key — safe to ship to the browser, used by the dashboard UI
SUPABASE_ANON_KEY=eyJhbGciOi...

# service_role key — SERVER ONLY. Bypasses Row-Level Security. Never expose.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── Ingest auth ───────────────────────────────────────────────────────────────
# Shared secret baked into the installer. Collectors send this in the
# X-Ingest-Token header so randoms can't POST junk to /api/ingest.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
INGEST_TOKEN=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ── Storage bucket ────────────────────────────────────────────────────────────
# Supabase Storage bucket where raw JSONL files are uploaded.
# Created by the schema migration; you should not need to change this.
STORAGE_BUCKET=claude-raw

# ── Team Activity page (claude.ai admin analytics) ────────────────────────────
# NOTE: No env vars needed anymore. The Team Activity tab is now DB-backed:
# the collector (ClaudeUsageCollector.exe `team-activity`) runs DAILY on an
# admin's machine, fetches claude.ai's per-user admin analytics for each org
# configured in its config.json (analytics_orgs: org + full Cookie header), and
# pushes it to the team_activity_* tables via /api/ingest. The dashboard just
# reads the DB — the Vercel server never calls claude.ai (Cloudflare blocks its
# IP). The old server-side proxy (CLAUDE_SESSION_KEY / CLAUDE_ANALYTICS_ORG) is
# removed; you can delete those Vercel env vars.
